{{!-- assets/javascripts/discourse/templates/streams.hbs --}}
<div class="streamers-page">
  <h1 class="streamers-title">
    {{i18n "streamers.title"}}
  </h1>

  {{#if this.model.live_streams}}
    <div class="streamers-list">
      {{#each this.model.live_streams as |stream|}}
        <article class="stream-card">
          <div class="stream-card-avatar">
            {{avatar stream username=stream.username size="huge"}}
          </div>

          <div class="stream-card-body">
            <div class="stream-card-header">
              <div class="stream-card-name">
                {{stream.name}}
              </div>
              <span class="stream-card-status">LIVE</span>
            </div>

            <div class="stream-card-meta">
              <span class="stream-card-listeners">
                {{stream.listeners}}
                {{i18n "streamers.listeners" count=stream.listeners}}
              </span>
              <span class="stream-card-dot">•</span>
              <span class="stream-card-bitrate">
                {{stream.bitrate}} kbps
              </span>
            </div>
          </div>
        </article>
      {{/each}}
    </div>
  {{else}}
    <p class="streamers-empty">
      {{i18n "streamers.no_streams"}}
    </p>
  {{/if}}

  <div class="streamers-updated">
    {{i18n "streamers.last_updated" time=this.model.updated_at}}
  </div>
</div>
