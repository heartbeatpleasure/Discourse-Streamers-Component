<div class="hb-streams-page">
  <header class="hb-streams-header">
    <h1 class="hb-streams-title">{{i18n "streamers.title"}}</h1>
    <div class="hb-streams-title-underline"></div>
  </header>

  {{#if this.model.live_streams}}
    <section class="hb-streams-list">
      {{#each this.model.live_streams as |stream|}}
        <article class="hb-stream-card">
          <div class="hb-stream-card-inner">
            <div class="hb-stream-avatar">
              {{avatar stream imageSize="huge"}}
            </div>

            <div class="hb-stream-content">
              <div class="hb-stream-header-row">
                <a
                  href="/u/{{stream.username}}"
                  class="hb-stream-name"
                >
                  {{stream.name}}
                </a>

                <span class="hb-stream-live-pill">
                  LIVE
                </span>
              </div>

              <div class="hb-stream-meta-row">
                <span class="hb-stream-listeners">
                  {{i18n "streamers.listeners" count=stream.listeners}}
                </span>
                <span class="hb-stream-bullet">•</span>
                <span class="hb-stream-bitrate">
                  {{stream.bitrate}} kbps
                </span>
              </div>

              <div class="hb-stream-actions-row">
                <a
                  class="hb-stream-listen-button"
                  href="https://stream.heartbeatpleasure.com/radio{{stream.mount}}"
                  target="_blank"
                  rel="noopener"
                >
                  {{i18n "streamers.listen"}}
                </a>
              </div>
            </div>
          </div>
        </article>
      {{/each}}
    </section>
  {{else}}
    <p class="hb-streams-empty">
      {{i18n "streamers.no_streams"}}
    </p>
  {{/if}}

  <p class="hb-streams-updated">
    {{i18n "streamers.last_updated" time=this.model.updated_at}}
  </p>
</div>
